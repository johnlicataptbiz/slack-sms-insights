generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id             String    @id @db.Uuid
  contactKey     String    @map("contact_key")
  status         String
  createdAt      DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @map("updated_at") @db.Timestamptz(6)
  nextFollowupAt DateTime? @map("next_followup_due_at") @db.Timestamptz(6)

  @@map("conversations")
}
