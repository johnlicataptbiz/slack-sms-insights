model draft_suggestions {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id        String       @db.Uuid
  prompt_snapshot_hash   String
  retrieved_exemplar_ids Json?
  generated_text         String
