generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactKey              String                   @unique @map("contact_key")
  contact_id              String?
  contact_phone           String?
  current_rep_id          String?
  status                  String                   @default("open")
  last_inbound_at         DateTime?                @db.Timestamptz(6)
  last_outbound_at        DateTime?                @db.Timestamptz(6)
  last_touch_at           DateTime?                @db.Timestamptz(6)
  unreplied_inbound_count Int                      @default(0)
  nextFollowupAt          DateTime?                @map("next_followup_due_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  conversation_notes      conversation_notes[]
  conversation_state      conversation_state?
  draft_suggestions       draft_suggestions[]
  inbox_contact_profiles  inbox_contact_profiles[]
  send_attempts           send_attempts[]
  sms_events              sms_events[]
  work_items              work_items?

  @@index([contactKey], map: "idx_conversations_contact_key")
  @@index([nextFollowupAt], map: "idx_conversations_next_followup_due")
  @@index([current_rep_id, last_touch_at(sort: Desc)], map: "idx_conversations_rep_last_touch")
  @@index([status], map: "idx_conversations_status")
  @@map("conversations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model actor_directory {
  canonical_name String   @id
  role           String
  aliases        String[] @default([])
  active         Boolean  @default(true)
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([role, active], map: "idx_actor_directory_role_active")
}

model audit_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action        String    @db.VarChar(100)
  resource_type String    @db.VarChar(100)
  resource_id   String    @db.VarChar(255)
  user_id       String?   @db.VarChar(255)
  details       Json?     @default("{}")
  ip_address    String?   @db.Inet
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([action], map: "idx_audit_logs_action")
  @@index([created_at(sort: Desc)], map: "idx_audit_logs_created_at")
}

model booked_call_attribution {
  booked_call_id             String   @id @db.Uuid
  booked_event_ts            DateTime @db.Timestamptz(6)
  booked_text                String?
  canonical_booking          Boolean  @default(false)
  mapping_method             String?
  match_confidence           Decimal? @db.Decimal(5, 3)
  conversation_id            String?  @db.Uuid
  conversation_match_seconds Int?
  setter_hint                String?
  setter_final               String?
  closer_final               String?
  first_conversion           String?
  source_bucket              String?
  hubspot_contact_id         String?
  lead_score                 Decimal? @db.Decimal
  lead_score_source          String?
  mapper_version             String   @default("v1.0")
  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime @default(now()) @db.Timestamptz(6)

  @@index([conversation_id], map: "idx_booked_call_attribution_conversation_id")
  @@index([booked_event_ts(sort: Desc)], map: "idx_booked_call_attribution_event_ts")
  @@index([setter_final], map: "idx_booked_call_attribution_setter_final")
}

model booked_call_reactions {
  booked_call_id String       @db.Uuid
  reaction_name  String
  reaction_count Int          @default(0)
  users          Json?
  updated_at     DateTime     @default(now()) @db.Timestamptz(6)
  booked_calls   booked_calls @relation(fields: [booked_call_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([booked_call_id, reaction_name])
}

model booked_calls {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slack_team_id         String
  slack_channel_id      String
  slack_message_ts      String
  event_ts              DateTime                @db.Timestamptz(6)
  text                  String?
  raw                   Json?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  first_sms_touch_at    DateTime?               @db.Timestamptz(6)
  booked_call_reactions booked_call_reactions[]

  @@unique([slack_channel_id, slack_message_ts])
  @@index([slack_channel_id, slack_message_ts], map: "idx_booked_calls_channel_ts")
  @@index([event_ts(sort: Desc)], map: "idx_booked_calls_event_ts")
}

model conversation_notes {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String       @db.Uuid
  author          String
  text            String
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  conversations   Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "idx_conv_notes_cid")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model conversation_state {
  conversation_id                 String       @id @db.Uuid
  qualification_full_or_part_time String       @default("unknown")
  qualification_niche             String?
  qualification_revenue_mix       String       @default("unknown")
  qualification_coaching_interest String       @default("unknown")
  qualification_progress_step     Int          @default(0)
  escalation_level                Int          @default(1)
  escalation_reason               String?
  escalation_overridden           Boolean      @default(false)
  last_podcast_sent_at            DateTime?    @db.Timestamptz(6)
  next_followup_due_at            DateTime?    @db.Timestamptz(6)
  cadence_status                  String       @default("idle")
  created_at                      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime     @default(now()) @db.Timestamptz(6)
  objection_tags                  String[]     @default([])
  guardrail_override_count        Int          @default(0)
  call_outcome                    String?
  qualification_delivery_model    String       @default("unknown")
  conversations                   Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cadence_status], map: "idx_conversation_state_cadence_status")
  @@index([qualification_coaching_interest], map: "idx_conversation_state_coaching_interest")
  @@index([conversation_id], map: "idx_conversation_state_conversation_id")
  @@index([escalation_level], map: "idx_conversation_state_escalation_level")
  @@index([objection_tags], map: "idx_conversation_state_objection_tags_gin", type: Gin)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
